#!groovy

pipeline {
    agent none

    environment {
        IMAGE_NAME_API = "olx-asp-api"
        IMAGE_NAME_FRONT = "olx-client"
    }

    stages {

        stage("Build Back") {
            agent { label 'gosell' }
            steps {
                echo 'Building back image ...'
                sh """
                    cd OLX.API
                    docker build --no-cache \
                        -t ${IMAGE_NAME_API}:${env.BUILD_NUMBER} \
                        -t ${IMAGE_NAME_API}:latest \
                        .
                    cd ..    
                """
            }
        }

        stage("Build Front") {
            agent { label 'gosell' }
            steps {
                echo 'Building front image ...'
                sh """
                    cd OLX.Frontend
                    docker build --no-cache \
                        -t ${IMAGE_NAME_FRONT}:${env.BUILD_NUMBER} \
                        -t ${IMAGE_NAME_FRONT}:latest \
                        .
                    cd ..    
                """
            }
        }

        stage("Deploy GoSell on remote server") {
            agent { label 'gosell' }
            steps {
                echo "Deploying GoSell on remote server ..."  
                sh """

                        echo "🧹 Cleaning up old Nagios container and image..."
                        docker stop \$(docker ps -a -q) || true
                        docker rm \$(docker ps -a -q) || true
                        docker rmi -f \$(docker images -aq) || true
                        docker compose down --remove-orphans || true

                        IMAGE_TAG=${env.BUILD_NUMBER} docker compose up -d
                        docker image prune -f
                """
            }
        }

    }
}